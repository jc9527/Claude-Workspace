@page "/"
@inject IFileService FileService
@inject IFolderService FolderService
@inject IConfigService ConfigService
@inject HttpClient Http
@inject IJSRuntime JS

<div class="filemanager-page">
    <div class="header">
        <h1>📁 檔案管理器</h1>
        <span class="root-folder">根目錄：@currentPath</span>
    </div>

    <div class="main-layout">
        <aside class="sidebar">
            <h3>📂 資料夾樹</h3>
            @if (folderTreeNodes != null && folderTreeNodes.Any())
            {
                <ul class="tree-list">
                @foreach (var node in folderTreeNodes)
                {
                    <li @onclick="() => NavigateTo(node.Path)">
                        <i class="rz-icon rzi-folder"></i> @node.Name
                    </li>
                }
                </ul>
            }
            else
            {
                <div class="loading">載入資料夾樹...</div>
            }
        </aside>
        
        <main class="content">
            @* Toolbar *@
            <div class="file-toolbar">
                <div class="toolbar-left">
                    <button @onclick="Refresh" title="重新整理">
                        <i class="rz-icon rzi-refresh"></i> 重新整理
                    </button>
                    <button @onclick="GoUp" title="回到上層" disabled="@(!CanGoUp)">
                        <i class="rz-icon rzi-arrow-up"></i> 上一層
                    </button>
                    @if (selectedItems.Any())
                    {
                        <button @onclick="ShowMultiDownload" title="下載選取的檔案" class="btn-selected">
                            <i class="rz-icon rzi-download"></i> 下載 (@selectedItems.Count)
                        </button>
                        <button @onclick="ClearSelection" title="清除選取">
                            <i class="rz-icon rzi-times"></i> 清除
                        </button>
                    }
                </div>
                
                <div class="toolbar-center">
                    <div class="search-box">
                        <i class="rz-icon rzi-search"></i>
                        <input type="text" @bind="searchKeyword" @bind:event="oninput" 
                               placeholder="搜尋檔案..." 
                               @onkeyup="OnSearchKeyUp" />
                        @if (!string.IsNullOrEmpty(searchKeyword))
                        {
                            <button class="clear-btn" @onclick="ClearSearch">
                                <i class="rz-icon rzi-times"></i>
                            </button>
                        }
                    </div>
                </div>
                
                <div class="toolbar-right">
                    <button @onclick="ShowNewFolderDialog" title="新增資料夾">
                        <i class="rz-icon rzi-folder-plus"></i> 新增資料夾
                    </button>
                    <button @onclick="ShowUploadDialog" title="上傳檔案">
                        <i class="rz-icon rzi-upload"></i> 上傳
                    </button>
                </div>
            </div>
            
            @* Search Results Header *@
            @if (isSearching)
            {
                <div class="search-results-header">
                    <span>搜尋結果：@searchKeyword</span>
                    <button @onclick="ClearSearch">✕ 清除搜尋</button>
                </div>
            }
            
            @* File List *@
            <div class="file-list">
                <table>
                    <thead>
                        <tr>
                            <th class="col-select">
                                <input type="checkbox" 
                                       checked="@IsAllSelected"
                                       @onclick="ToggleSelectAll" />
                            </th>
                            <th class="col-name">名稱</th>
                            <th class="col-size">大小</th>
                            <th class="col-date">修改日期</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (displayItems != null && displayItems.Any())
                        {
                            @foreach (var item in displayItems)
                            {
                                <tr class="@(selectedItems.Contains(item) ? "selected" : "")"
                                    @ondblclick="() => EnterFolder(item)"
                                    @oncontextmenu:preventDefault="true"
                                    @oncontextmenu="(e) => ShowContextMenu(item, e)">
                                    <td class="col-select" @onclick:stopPropagation="true">
                                        <input type="checkbox" 
                                               checked="@selectedItems.Contains(item)"
                                               @onclick="() => ToggleSelectItem(item)" />
                                    </td>
                                    <td class="col-name">
                                        @if (item.IsDirectory)
                                        {
                                            <i class="rz-icon rzi-folder" style="color: #ffc107;"></i>
                                        }
                                        else
                                        {
                                            <i class="rz-icon rzi-file" style="color: #6c757d;"></i>
                                        }
                                        @item.Name
                                    </td>
                                    <td class="col-size">@(item.IsDirectory ? "-" : FormatSize(item.Size))</td>
                                    <td class="col-date">@item.LastModified.ToString("yyyy-MM-dd HH:mm")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="empty-state">
                                    @(isSearching ? "找不到符合的檔案" : "此資料夾為空")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </main>
    </div>
</div>

@* Context Menu *@
@if (showContextMenu && contextMenuItem != null)
{
    <div class="context-menu" style="left: @contextMenuX px; top: @contextMenuY px;" @onclick:stopPropagation="true">
        <div class="context-menu-item" @onclick="() => OpenRename(contextMenuItem)">
            <i class="rz-icon rzi-edit"></i> 重新命名
        </div>
        <div class="context-menu-item" @onclick="() => OpenMove(contextMenuItem)">
            <i class="rz-icon rzi-folder-move"></i> 移動到...
        </div>
        @if (!contextMenuItem.IsDirectory)
        {
            <div class="context-menu-item" @onclick="() => DownloadFile(contextMenuItem)">
                <i class="rz-icon rzi-download"></i> 下載
            </div>
        }
        <div class="context-menu-separator"></div>
        <div class="context-menu-item danger" @onclick="() => ShowDeleteConfirm(contextMenuItem)">
            <i class="rz-icon rzi-trash"></i> 刪除
        </div>
    </div>
}

@* New Folder Dialog *@
@if (showNewFolderDialog)
{
    <div class="dialog-overlay" @onclick="CloseNewFolderDialog">
        <div class="dialog-content" @onclick:stopPropagation="true">
            <h3>📁 新增資料夾</h3>
            <div class="form-group">
                <label>資料夾名稱：</label>
                <input type="text" @bind="newFolderName" @bind:event="oninput" 
                       placeholder="請輸入資料夾名稱" 
                       @onkeyup="OnNewFolderKeyUp" autofocus />
            </div>
            <div class="dialog-actions">
                <button class="btn-primary" @onclick="CreateFolder" disabled="@string.IsNullOrWhiteSpace(newFolderName)">
                    建立
                </button>
                <button class="btn-secondary" @onclick="CloseNewFolderDialog">
                    取消
                </button>
            </div>
        </div>
    </div>
}

@* Rename Dialog *@
@if (showRenameDialog && renameItem != null)
{
    <div class="dialog-overlay" @onclick="CloseRenameDialog">
        <div class="dialog-content" @onclick:stopPropagation="true">
            <h3>✏️ 重新命名</h3>
            <div class="current-name">
                <label>目前名稱：</label>
                <code>@renameItem.Name</code>
            </div>
            <div class="form-group">
                <label>新名稱：</label>
                <input type="text" @bind="newFileName" @bind:event="oninput" 
                       placeholder="請輸入新名稱" 
                       @onkeyup="OnRenameKeyUp" autofocus />
            </div>
            @if (!string.IsNullOrEmpty(renameError))
            {
                <div class="error-message">@renameError</div>
            }
            <div class="dialog-actions">
                <button class="btn-primary" @onclick="ConfirmRename" disabled="@string.IsNullOrWhiteSpace(newFileName)">
                    確定
                </button>
                <button class="btn-secondary" @onclick="CloseRenameDialog">
                    取消
                </button>
            </div>
        </div>
    </div>
}

@* Move Dialog *@
@if (showMoveDialog && moveItem != null)
{
    <div class="dialog-overlay" @onclick="CloseMoveDialog">
        <div class="dialog-content move-dialog" @onclick:stopPropagation="true">
            <h3>📂 移動項目</h3>
            <div class="current-name">
                <label>移動：</label>
                <code>@moveItem.Name</code>
            </div>
            <div class="form-group">
                <label>目標資料夾：</label>
                <div class="folder-tree-select">
                    @foreach (var folder in availableFolders)
                    {
                        <div class="folder-option @(folder.Path == selectedMovePath ? "selected" : "")"
                             @onclick="() => SelectMovePath(folder.Path)">
                            <i class="rz-icon rzi-folder"></i>
                            @folder.Path
                        </div>
                    }
                </div>
            </div>
            <div class="dialog-actions">
                <button class="btn-primary" @onclick="ConfirmMove" disabled="@string.IsNullOrEmpty(selectedMovePath)">
                    移動
                </button>
                <button class="btn-secondary" @onclick="CloseMoveDialog">
                    取消
                </button>
            </div>
        </div>
    </div>
}

@* Delete Confirm Dialog *@
@if (showDeleteDialog && deleteItem != null)
{
    <div class="dialog-overlay" @onclick="CloseDeleteDialog">
        <div class="dialog-content" @onclick:stopPropagation="true">
            <h3>⚠️ 確認刪除</h3>
            <div class="delete-warning">
                <p>確定要刪除以下項目嗎？</p>
                <div class="item-info">
                    @if (deleteItem.IsDirectory)
                    {
                        <i class="rz-icon rzi-folder" style="color: #ffc107;"></i>
                    }
                    else
                    {
                        <i class="rz-icon rzi-file" style="color: #6c757d;"></i>
                    }
                    <code>@deleteItem.Name</code>
                </div>
                @if (deleteItem.IsDirectory)
                {
                    <p class="warning-text">⚡ 此操作將刪除資料夾及其所有內容，且無法復原！</p>
                }
                else
                {
                    <p class="warning-text">⚡ 此操作無法復原！</p>
                }
            </div>
            <div class="dialog-actions">
                <button class="btn-danger" @onclick="ConfirmDelete">
                    刪除
                </button>
                <button class="btn-secondary" @onclick="CloseDeleteDialog">
                    取消
                </button>
            </div>
        </div>
    </div>
}

@* Upload Dialog *@
@if (showUploadDialog)
{
    <div class="dialog-overlay" @onclick="CloseUploadDialog">
        <div class="dialog-content upload-dialog" @onclick:stopPropagation="true">
            <h3>📤 上傳檔案</h3>
            
            @* Drag and Drop Zone *@
            <div class="upload-area @dragOverClass"
                 @ondragover:preventDefault="true"
                 @ondragover="@(() => dragOverClass = "drag-over")"
                 @ondragleave="HandleDragLeave"
                 @ondrop="OnDrop">
                <i class="rz-icon rzi-cloud-upload" style="font-size: 3rem; color: #6c757d;"></i>
                <p>拖曳檔案到這裡</p>
                <p class="or-text">或</p>
                <InputFile OnChange="OnFilesSelected" multiple style="display: none;" id="fileInput" />
                <label class="file-input-label" for="fileInput">
                    選擇檔案
                </label>
                <p class="hint">支援多檔案上傳（拖曳亦可）</p>
            </div>
            
            @if (selectedFiles.Any())
            {
                <div class="file-list">
                    <h4>已選擇的檔案：（@selectedFiles.Count 個）</h4>
                    @foreach (var file in selectedFiles)
                    {
                        <div class="file-item">
                            <i class="rz-icon rzi-file" style="color: #6c757d;"></i>
                            <span>@file.Name</span>
                            <span class="file-size">(@FormatSize(file.Size))</span>
                        </div>
                    }
                </div>
            }
            
            <div class="destination-path">
                <label>上傳至：</label>
                <code>@currentPath</code>
            </div>
            
            <div class="overwrite-option">
                <label>
                    <input type="checkbox" @bind="overwriteExisting" />
                    覆蓋已存在的檔案
                </label>
            </div>
            
            @if (!string.IsNullOrEmpty(uploadError))
            {
                <div class="error-message">@uploadError</div>
            }
            
            @if (isUploading)
            {
                <div class="progress-bar">
                    <div class="progress" style="width: @uploadProgress%"></div>
                </div>
                <p class="uploading-text">上傳中... @uploadProgress%</p>
            }
            
            <div class="dialog-actions">
                <button class="btn-primary" @onclick="UploadFiles" disabled="@(!selectedFiles.Any() || isUploading)">
                    上傳
                </button>
                <button class="btn-secondary" @onclick="CloseUploadDialog" disabled="@isUploading">
                    取消
                </button>
            </div>
        </div>
    </div>
}

@code {
    private string currentPath = "/home/devpro/data";
    private List<FileItem> fileItems = new();
    private List<FileItem> searchResults = new();
    private List<FolderTreeNode> folderTreeNodes = new();
    
    private bool showNewFolderDialog = false;
    private bool showRenameDialog = false;
    private bool showDeleteDialog = false;
    private bool showUploadDialog = false;
    private bool showContextMenu = false;
    private bool showMoveDialog = false;
    
    private string newFolderName = "";
    private FileItem? renameItem = null;
    private FileItem? deleteItem = null;
    private FileItem? moveItem = null;
    private FileItem? contextMenuItem = null;
    private string newFileName = "";
    private string renameError = "";
    
    private List<IBrowserFile> selectedFiles = new();
    private bool overwriteExisting = false;
    private bool isUploading = false;
    private int uploadProgress = 0;
    private string uploadError = "";
    private string dragOverClass = "";
    
    private bool isSearching = false;
    private string searchKeyword = "";
    
    private int contextMenuX = 0;
    private int contextMenuY = 0;
    
    // Multi-select
    private HashSet<FileItem> selectedItems = new();
    
    // Move dialog
    private List<FolderTreeNode> availableFolders = new();
    private string selectedMovePath = "";
    
    private List<FileItem> displayItems => isSearching ? searchResults : fileItems;
    private bool CanGoUp => currentPath != "/home/devpro/data";
    private bool IsAllSelected => displayItems.Any() && displayItems.All(i => selectedItems.Contains(i));

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
    }

    private async Task Refresh()
    {
        try
        {
            var fileResult = await FileService.GetFilesAsync(currentPath);
            if (fileResult != null)
            {
                fileItems = fileResult.Items ?? new List<FileItem>();
            }

            var treeResult = await FolderService.GetFolderTreeAsync(currentPath);
            if (treeResult != null && treeResult.Nodes != null)
            {
                folderTreeNodes = treeResult.Nodes;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading: {ex.Message}");
        }
    }

    private async Task NavigateTo(string path)
    {
        currentPath = path;
        isSearching = false;
        ClearSelection();
        await Refresh();
    }

    private async Task EnterFolder(FileItem item)
    {
        if (item.IsDirectory)
        {
            currentPath = item.Path;
            isSearching = false;
            ClearSelection();
            await Refresh();
        }
    }

    private async Task GoUp()
    {
        if (CanGoUp)
        {
            var parentPath = System.IO.Path.GetDirectoryName(currentPath) ?? "/home/devpro/data";
            await NavigateTo(parentPath);
        }
    }

    // ==================== Multi-Select ====================
    private void ToggleSelectItem(FileItem item)
    {
        if (selectedItems.Contains(item))
            selectedItems.Remove(item);
        else
            selectedItems.Add(item);
    }

    private void ToggleSelectAll()
    {
        if (IsAllSelected)
            selectedItems.Clear();
        else
        {
            selectedItems.Clear();
            foreach (var item in displayItems)
                selectedItems.Add(item);
        }
    }

    private void ClearSelection()
    {
        selectedItems.Clear();
    }

    // ==================== Multi-Download ====================
    private void ShowMultiDownload()
    {
        if (selectedItems.Any())
        {
            // Download all selected files as individual downloads
            foreach (var item in selectedItems.Where(i => !i.IsDirectory))
            {
                DownloadFile(item);
            }
            ClearSelection();
        }
    }

    // ==================== New Folder ====================
    private void ShowNewFolderDialog()
    {
        showNewFolderDialog = true;
        newFolderName = "";
        showContextMenu = false;
    }

    private void CloseNewFolderDialog()
    {
        showNewFolderDialog = false;
        newFolderName = "";
    }

    private async Task CreateFolder()
    {
        if (!string.IsNullOrWhiteSpace(newFolderName))
        {
            try
            {
                await FolderService.CreateFolderAsync(currentPath, newFolderName);
                CloseNewFolderDialog();
                await Refresh();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error creating folder: {ex.Message}");
            }
        }
    }

    private async Task OnNewFolderKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(newFolderName))
        {
            await CreateFolder();
        }
    }

    // ==================== Context Menu ====================
    private void ShowContextMenu(FileItem item, MouseEventArgs e)
    {
        contextMenuItem = item;
        contextMenuX = (int)e.ClientX;
        contextMenuY = (int)e.ClientY;
        showContextMenu = true;
    }

    private void CloseContextMenu()
    {
        showContextMenu = false;
        contextMenuItem = null;
    }

    // ==================== Rename ====================
    private void OpenRename(FileItem item)
    {
        CloseContextMenu();
        renameItem = item;
        newFileName = item.Name;
        renameError = "";
        showRenameDialog = true;
    }

    private void CloseRenameDialog()
    {
        showRenameDialog = false;
        renameItem = null;
        newFileName = "";
        renameError = "";
    }

    private async Task ConfirmRename()
    {
        if (renameItem == null || string.IsNullOrWhiteSpace(newFileName))
            return;

        if (newFileName.IndexOfAny(System.IO.Path.GetInvalidFileNameChars()) >= 0)
        {
            renameError = "名稱包含無效字元";
            return;
        }

        try
        {
            var parentDir = System.IO.Path.GetDirectoryName(renameItem.Path) ?? currentPath;
            var newPath = System.IO.Path.Combine(parentDir, newFileName);
            await FileService.MoveFileAsync(new List<string> { renameItem.Path }, newPath);
            CloseRenameDialog();
            await Refresh();
        }
        catch (Exception ex)
        {
            renameError = ex.Message;
        }
    }

    private async Task OnRenameKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(newFileName))
        {
            await ConfirmRename();
        }
        else if (e.Key == "Escape")
        {
            CloseRenameDialog();
        }
    }

    // ==================== Move ====================
    private async Task OpenMove(FileItem item)
    {
        CloseContextMenu();
        moveItem = item;
        selectedMovePath = currentPath;
        showMoveDialog = true;
        
        // Load available folders
        try
        {
            var treeResult = await FolderService.GetFolderTreeAsync("/home/devpro/data");
            if (treeResult != null && treeResult.Nodes != null)
            {
                availableFolders = treeResult.Nodes;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading folders: {ex.Message}");
        }
    }

    private void SelectMovePath(string path)
    {
        selectedMovePath = path;
    }

    private void CloseMoveDialog()
    {
        showMoveDialog = false;
        moveItem = null;
        availableFolders.Clear();
        selectedMovePath = "";
    }

    private async Task ConfirmMove()
    {
        if (moveItem == null || string.IsNullOrEmpty(selectedMovePath))
            return;

        try
        {
            var newPath = System.IO.Path.Combine(selectedMovePath, moveItem.Name);
            await FileService.MoveFileAsync(new List<string> { moveItem.Path }, newPath);
            CloseMoveDialog();
            await Refresh();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error moving: {ex.Message}");
        }
    }

    // ==================== Delete ====================
    private void ShowDeleteConfirm(FileItem item)
    {
        CloseContextMenu();
        deleteItem = item;
        showDeleteDialog = true;
    }

    private void CloseDeleteDialog()
    {
        showDeleteDialog = false;
        deleteItem = null;
    }

    private async Task ConfirmDelete()
    {
        if (deleteItem == null)
            return;

        try
        {
            if (deleteItem.IsDirectory)
            {
                await FolderService.DeleteFolderAsync(deleteItem.Path);
            }
            else
            {
                await FileService.DeleteFileAsync(deleteItem.Path);
            }
            CloseDeleteDialog();
            await Refresh();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting: {ex.Message}");
        }
    }

    // ==================== Download ====================
    private void DownloadFile(FileItem item)
    {
        CloseContextMenu();
        if (!item.IsDirectory)
        {
            JS.InvokeVoidAsync("eval", $"window.location.href = '/api/files/download?path={Uri.EscapeDataString(item.Path)}'");
        }
    }

    // ==================== Upload ====================
    private void ShowUploadDialog()
    {
        showUploadDialog = true;
        selectedFiles.Clear();
        overwriteExisting = false;
        uploadError = "";
        isUploading = false;
        uploadProgress = 0;
        showContextMenu = false;
    }

    private void CloseUploadDialog()
    {
        if (!isUploading)
        {
            showUploadDialog = false;
            selectedFiles.Clear();
        }
    }

    private void OnFilesSelected(InputFileChangeEventArgs e)
    {
        selectedFiles.Clear();
        foreach (var file in e.GetMultipleFiles())
        {
            selectedFiles.Add(file);
        }
        StateHasChanged();
    }

    private void OnDrop(DragEventArgs e)
    {
        dragOverClass = "";
        // Note: Drag and drop file handling requires JS interop
        // For now, use the file input button to select files
    }

    private void HandleDragLeave(DragEventArgs e)
    {
        dragOverClass = "";
    }

    private async Task UploadFiles()
    {
        if (!selectedFiles.Any())
            return;

        isUploading = true;
        uploadError = "";
        uploadProgress = 0;

        try
        {
            var totalFiles = selectedFiles.Count;
            var uploadedCount = 0;

            foreach (var file in selectedFiles)
            {
                var content = new MultipartFormDataContent();
                var fileContent = new StreamContent(file.OpenReadStream(maxAllowedSize: 1024L * 1024L * 1024L));
                content.Add(fileContent, "files", file.Name);
                content.Add(new StringContent(currentPath), "destinationPath");
                content.Add(new StringContent(overwriteExisting.ToString().ToLower()), "overwrite");

                var response = await Http.PostAsync("/api/upload", content);

                if (response.IsSuccessStatusCode)
                {
                    uploadedCount++;
                }

                uploadProgress = (int)((uploadedCount / (double)totalFiles) * 100);
                StateHasChanged();
            }

            CloseUploadDialog();
            await Refresh();
        }
        catch (Exception ex)
        {
            uploadError = $"上傳失敗：{ex.Message}";
        }
        finally
        {
            isUploading = false;
        }
    }

    // ==================== Search ====================
    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await PerformSearch();
        }
    }

    private async Task PerformSearch()
    {
        if (string.IsNullOrWhiteSpace(searchKeyword))
        {
            ClearSearch();
            return;
        }

        isSearching = true;

        try
        {
            var request = new SearchRequest
            {
                SearchPath = currentPath,
                Keyword = searchKeyword
            };
            var response = await FileService.SearchFilesAsync(request);
            if (response != null)
            {
                searchResults = response.Results ?? new List<FileItem>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Search error: {ex.Message}");
            searchResults = new List<FileItem>();
        }
    }

    private void ClearSearch()
    {
        isSearching = false;
        searchKeyword = "";
        searchResults.Clear();
    }

    // ==================== Utilities ====================
    private string FormatSize(long size)
    {
        string[] suffixes = { "B", "KB", "MB", "GB", "TB" };
        int order = 0;
        double len = size;
        while (len >= 1024 && order < suffixes.Length - 1)
        {
            order++;
            len /= 1024;
        }
        return $"{len:0.##} {suffixes[order]}";
    }
}


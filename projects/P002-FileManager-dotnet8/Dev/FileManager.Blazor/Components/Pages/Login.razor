@page "/login"
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="login-page">
    <div class="login-card">
        <h2>📁 檔案管理器</h2>
        <h3>登入</h3>
        
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-message">@errorMessage</div>
        }
        
        <form @onsubmit:preventDefault="true">
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" @bind="email" placeholder="your@email.com" />
            </div>
            
            <div class="form-group">
                <label for="password">密碼</label>
                <input type="password" id="password" @bind="password" placeholder="••••••••" />
            </div>
            
            <button type="button" @onclick="HandleLogin" disabled="@isLoading">
                @(isLoading ? "登入中..." : "登入")
            </button>
        </form>
        
        <div class="login-hint">
            <p>💡 提示：測試帳號</p>
            <p>• admin@devpro.com.tw (管理員，可見所有網域)</p>
            <p>• johnny@sinopac.com (一般使用者)</p>
            <p>• 密碼 = Email</p>
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string errorMessage = "";
    private bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        // Check if already logged in via JS
        try
        {
            var isLoggedIn = await JS.InvokeAsync<bool>("checkAuth");
            if (isLoggedIn)
            {
                Navigation.NavigateTo("/", forceLoad: true);
            }
        }
        catch
        {
            // Ignore
        }
    }

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "請輸入 Email 和密碼";
            return;
        }

        isLoading = true;
        errorMessage = "";

        try
        {
            // Call JS login + navigation directly
            await JS.InvokeVoidAsync("performLoginAndRedirect", email, password);
        }
        catch (Exception ex)
        {
            errorMessage = "登入失敗：" + (ex.Message ?? "連線中斷");
        }
        finally
        {
            isLoading = false;
        }
    }

    public class LoginResult
    {
        public bool Success { get; set; }
        public string Message { get; set; } = "";
    }
}

<style>
.login-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.login-card {
    background: white;
    padding: 2rem;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    width: 100%;
    max-width: 400px;
}

.login-card h2 {
    margin: 0 0 0.5rem 0;
    color: #333;
    text-align: center;
}

.login-card h3 {
    margin: 0 0 1.5rem 0;
    color: #666;
    text-align: center;
    font-weight: normal;
}

.form-group {
    margin-bottom: 1rem;
}

.form-group label {
    display: block;
    margin-bottom: 0.5rem;
    color: #333;
    font-weight: 500;
}

.form-group input {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 1rem;
    box-sizing: border-box;
}

.form-group input:focus {
    outline: none;
    border-color: #667eea;
}

button {
    width: 100%;
    padding: 0.75rem;
    background: #667eea;
    color: white;
    border: none;
    border-radius: 4px;
    font-size: 1rem;
    cursor: pointer;
    margin-top: 0.5rem;
}

button:hover:not(:disabled) {
    background: #5568d3;
}

button:disabled {
    background: #ccc;
    cursor: not-allowed;
}

.error-message {
    background: #fee2e2;
    color: #dc3545;
    padding: 0.75rem;
    border-radius: 4px;
    margin-bottom: 1rem;
    text-align: center;
}

.login-hint {
    margin-top: 1.5rem;
    padding: 1rem;
    background: #f8f9fa;
    border-radius: 4px;
    font-size: 0.875rem;
    color: #666;
}

.login-hint p {
    margin: 0.25rem 0;
}
</style>

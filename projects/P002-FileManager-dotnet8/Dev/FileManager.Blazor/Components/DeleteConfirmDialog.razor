@namespace FileManager.Blazor.Components

@if (IsVisible)
{
    <div class="dialog-overlay" @onclick="Cancel">
        <div class="dialog-content" @onclick:stopPropagation="true">
            <h3>⚠️ 確認刪除</h3>
            
            <div class="delete-warning">
                <p>確定要刪除以下項目嗎？</p>
                <div class="item-info">
                    @if (IsDirectory)
                    {
                        <i class="rz-icon rzi-folder" style="color: #ffc107;"></i>
                    }
                    else
                    {
                        <i class="rz-icon rzi-file" style="color: #6c757d;"></i>
                    }
                    <code>@ItemName</code>
                </div>
                @if (IsDirectory)
                {
                    <p class="warning-text">⚡ 此操作將刪除資料夾及其所有內容，且無法復原！</p>
                }
                else
                {
                    <p class="warning-text">⚡ 此操作無法復原！</p>
                }
            </div>
            
            <div class="dialog-actions">
                <button class="btn-danger" @onclick="Confirm">
                    刪除
                </button>
                <button class="btn-secondary" @onclick="Cancel">
                    取消
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string ItemPath { get; set; } = "";
    [Parameter] public string ItemName { get; set; } = "";
    [Parameter] public bool IsDirectory { get; set; }
    [Parameter] public EventCallback<string> OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    public void Show(string path, string name, bool isDirectory)
    {
        ItemPath = path;
        ItemName = name;
        IsDirectory = isDirectory;
        IsVisible = true;
        StateHasChanged();
    }

    public void Hide()
    {
        IsVisible = false;
        ItemPath = "";
        ItemName = "";
        IsDirectory = false;
        StateHasChanged();
    }

    private async Task Confirm()
    {
        await OnConfirm.InvokeAsync(ItemPath);
        Hide();
    }

    private async Task Cancel()
    {
        await OnCancel.InvokeAsync();
        Hide();
    }
}

<style>
.dialog-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
}

.dialog-content {
    background: white;
    padding: 1.5rem;
    border-radius: 8px;
    min-width: 400px;
    max-width: 500px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
}

.dialog-content h3 {
    margin: 0 0 1rem 0;
    color: #333;
}

.delete-warning p {
    margin: 0 0 0.5rem 0;
}

.item-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem;
    background: #f8f9fa;
    border-radius: 4px;
    margin: 0.5rem 0;
}

.item-info code {
    word-break: break-all;
}

.warning-text {
    color: #dc3545;
    font-weight: 500;
}

.dialog-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
    margin-top: 1rem;
}

.dialog-actions button {
    padding: 0.5rem 1rem;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
}

.btn-danger {
    background: #dc3545;
    color: white;
    border: none;
}

.btn-danger:hover {
    background: #bb2d3b;
}

.btn-secondary {
    background: white;
    color: #333;
    border: 1px solid #ddd;
}

.btn-secondary:hover {
    background: #f8f9fa;
}
</style>
